@{
    ViewData["Title"] = "Dashboard";
}

<section class="mb-4">
    <div class="row g-3">
        <div class="col-sm-6 col-xl-3">
            <div class="card stat-card border-0 shadow-sm h-100">
                <div class="card-body">
                    <p class="text-muted mb-1">Members (active)</p>
                    <h3 class="mb-0">482</h3>
                    <small class="text-muted">Total members: 615</small>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="card stat-card border-0 shadow-sm h-100">
                <div class="card-body">
                    <p class="text-muted mb-1">Active memberships</p>
                    <h3 class="mb-0">401</h3>
                    <small class="text-muted">Expiring in 7 days: 23</small>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="card stat-card border-0 shadow-sm h-100">
                <div class="card-body">
                    <p class="text-muted mb-1">Bookings (today)</p>
                    <h3 class="mb-0">79</h3>
                    <small class="text-muted">Cancellations today: 6</small>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="card stat-card border-0 shadow-sm h-100">
                <div class="card-body">
                    <p class="text-muted mb-1">CMS content</p>
                    <h3 class="mb-0">128</h3>
                    <small class="text-muted">Pages: 6 • Text keys: 122</small>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="row g-3">
    <div class="col-xl-8">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h2 class="h6 mb-0">Upcoming classes</h2>
                <span class="badge text-bg-primary">Today</span>
            </div>

            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Class</th>
                            <th>Start</th>
                            <th>Room</th>
                            <th>Capacity</th>
                            <th>Bookings</th>
                            <th>Status</th>
                        </tr>
                    </thead>

                    <tbody>
                        <tr>
                            <td>Crossfit</td>
                            <td>18:00</td>
                            <td>A1</td>
                            <td>20</td>
                            <td><span class="badge text-bg-success">18 / 20</span></td>
                            <td><span class="badge text-bg-success">Open</span></td>
                        </tr>

                        <tr>
                            <td>Yoga</td>
                            <td>19:30</td>
                            <td>B3</td>
                            <td>15</td>
                            <td><span class="badge text-bg-warning">12 / 15</span></td>
                            <td><span class="badge text-bg-success">Open</span></td>
                        </tr>

                        <tr>
                            <td>Mobility</td>
                            <td>20:15</td>
                            <td>C2</td>
                            <td>10</td>
                            <td><span class="badge text-bg-danger">10 / 10</span></td>
                            <td><span class="badge text-bg-danger">Full</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="card-footer bg-white d-flex flex-wrap justify-content-between align-items-center gap-2">
                <small class="text-muted">Tip: capacity is based on FitnessClass.Capacity and bookings count.</small>
                <a class="btn btn-outline-primary btn-sm" href="#">View full schedule</a>
            </div>
        </div>
    </div>

    <div class="col-xl-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white">
                <h2 class="h6 mb-0">Quick actions</h2>
            </div>

            <div class="card-body d-grid gap-2">
                <a class="btn btn-primary" href="#">Add member</a>
                <a class="btn btn-outline-primary" href="#">Create membership plan</a>
                <a class="btn btn-outline-secondary" href="#">Add class to schedule</a>
                <a class="btn btn-outline-dark" href="#">Post announcement</a>
                <hr class="my-2" />
                <a class="btn btn-outline-success" href="#">Edit portal texts (CMS)</a>
                <a class="btn btn-outline-success" href="#">Edit portal pages (CMS)</a>
            </div>
        </div>
    </div>
</section>