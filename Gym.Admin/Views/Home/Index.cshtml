@model Gym.Admin.Models.Home.AdminDashboardViewModel

@{
    string GetText(string key, string fallback)
    {
        return Model.Parameters.ContainsKey(key) ? Model.Parameters[key] : fallback;
    }

    ViewData["Title"] = GetText("Admin.Dashboard.PageTitle", "Dashboard");
}

@await Html.PartialAsync("_AdminStatsCards", Model)

<section class="row g-3">
    @await Html.PartialAsync("_AdminUpcomingClasses", Model)
    @await Html.PartialAsync("_AdminQuickActions", Model)
</section>