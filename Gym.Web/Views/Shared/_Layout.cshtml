<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Gym.Web</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Gym.Web.styles.css" asp-append-version="true" />
</head>
<body>
    @{
        var parameters = ViewBag.Parameters as IDictionary<string, string> ?? new Dictionary<string, string>();
        var pages = ViewBag.PageModel as IEnumerable<Gym.Data.Models.Cms.PortalPage> ?? Enumerable.Empty<Gym.Data.Models.Cms.PortalPage>();
        string Txt(string key) => parameters.TryGetValue(key, out var value) && !string.IsNullOrWhiteSpace(value) ? value : $"[{key}]";
    }
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark web-navbar shadow-sm"> @* navbar-expand navbar sie rozwija lub zwija do hamburgera *@
            <div class="container"> @* responsywny kontener *@
                <a class="navbar-brand fw-semibold" asp-area="" asp-controller="Home" asp-action="Index">Gym.Web</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#webNavbar" aria-controls="webNavbar" aria-expanded="false" aria-label="Przełącz nawigację">
                    <span class="navbar-toggler-icon"></span>
                </button>
                @await Html.PartialAsync("Links", pages) @* wstawia zawartość z Links.cshtml, który generuje linki do stron CMS *@
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="web-footer py-4 mt-5 border-top">
        <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
            <small class="text-muted">&copy; @Txt("Footer.Copyright")</small>
            <a class="text-decoration-none small" asp-area="" asp-controller="Home" asp-action="Privacy">@Txt("Footer.PrivacyPolicy")</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script> @* skrypt do collapse (zwijany navbar) *@
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>