<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Gym.Web</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Gym.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark web-navbar shadow-sm"> @* navbar-expand navbar sie rozwija lub zwija do hamburgera *@
            <div class="container"> @* responsywny kontener *@
                <a class="navbar-brand fw-semibold" asp-area="" asp-controller="Home" asp-action="Index">Gym.Web</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#webNavbar" aria-controls="webNavbar" aria-expanded="false" aria-label="Przełącz nawigację">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="webNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Start</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#karnety">Memberships</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#grafik">Schedule</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#aktualnosci">Announcements</a>
                        </li>
                    </ul>
                    <a class="btn btn-light btn-sm px-3" href="#dashboard">My dashboard</a>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="web-footer py-4 mt-5 border-top">
        <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
            <small class="text-muted">&copy; 2026 Gym.Web - Customer Web Portal</small>
            <a class="text-decoration-none small" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy policy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script> @* skrypt do collapse (zwijany navbar) *@
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>