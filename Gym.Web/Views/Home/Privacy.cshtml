@{
    ViewData["Title"] = "Privacy Policy";
}
<section class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <h1 class="mb-4">@ViewData["Title"]</h1>
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <p>
                        This privacy policy describes how Gym.Web collects, uses, and protects personal data.
                    </p>
                    <p>
                        We process only data necessary to provide membership services, class bookings, and account support.
                    </p>
                    <p class="mb-0">
                        If you have any questions about data processing, please contact the club administration.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>
