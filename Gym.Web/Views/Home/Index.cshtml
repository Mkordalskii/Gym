@model Gym.Data.Models.Cms.PortalPage
@{
    var parameters = ViewBag.Parameters as Dictionary<string, string> ?? new Dictionary<string, string>();
    var membershipPlans = ViewBag.MembershipPlans as List<Gym.Data.Models.Core.MembershipPlan> ?? new List<Gym.Data.Models.Core.MembershipPlan>();
    var announcements = ViewBag.Announcements as List<Gym.Data.Models.Core.Announcement> ?? new List<Gym.Data.Models.Core.Announcement>();
    var nextClass = ViewBag.NextClass as Gym.Data.Models.Core.FitnessClass;
    var membership = ViewBag.ActiveMembership as Gym.Data.Models.Core.Membership;
    string GetText(string key, string fallback)
    {
        return parameters.ContainsKey(key) ? parameters[key] : fallback;
    }

    var upcomingClasses = ViewBag.UpcomingClasses as List<Gym.Data.Models.Core.FitnessClass>
        ?? new List<Gym.Data.Models.Core.FitnessClass>();

    var latestAnnouncement = announcements.FirstOrDefault();
    ViewData["Title"] = GetText("Home.PageTitle", "Customer web");
 }
<section class="hero-section py-5">
    <div class="container py-4">
        <div class="row align-items-center g-4">
            <div class="col-lg-7">
                <h1 class="display-5 fw-bold mb-3">@GetText("Home.HeroTitle", "Your fitness club portal")</h1>
                <p class="lead text-secondary mb-4">
                    @GetText("Home.HeroSubtitle", "Manage your membership, browse the schedule, and book classes in seconds.")
                </p>

                <div class="d-flex flex-wrap gap-2">
                    <a asp-controller="FitnessClasses" asp-action="Index" class="btn btn-primary btn-lg px-4">@GetText("Home.HeroPrimaryButton", "View schedule")</a>
                    <a asp-controller="MembershipPlans" asp-action="Index" class="btn btn-outline-primary btn-lg px-4">@GetText("Home.HeroSecondaryButton", "Membership plans")</a>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-lg px-4">@GetText("Home.HeroTertiaryButton", "My dashboard")</a>
                </div>

                <p class="text-muted mt-3 mb-0 small">
                    @GetText("Home.HeroTip", "Tip: booking requires an active membership.")
                </p>
            </div>

            <div class="col-lg-5">
                <div class="card border-0 shadow-sm hero-card">
                    @await Html.PartialAsync("_UpcomingClassesHome",new UpcomingClassesViewModel
                    {
                        Classes = upcomingClasses,
                        Parameters = parameters
                    })
                </div>
            </div>

        </div>
    </div>
</section>

<section id="dashboard" class="container my-5">
    <div class="row g-3">
        @await Html.PartialAsync("_ActiveMembershipHome",new ActiveMembershipViewModel
        {
            Membership = membership,
            Parameters = parameters
        })

        @await Html.PartialAsync("_UpcomingBookingHome",new UpcomingBookingViewModel  
        {
            FitnessClass = nextClass,
            Parameters = parameters
        })
        @if (latestAnnouncement != null)
        {
		    @await Html.PartialAsync("_AnnouncementsHomePage", latestAnnouncement) @* wstawia zawartość z AnnouncementsHomePage.cshtml, który pokazuje najnowsze ogłoszenie *@
        }
    </div>
</section>

<section id="karnety" class="container my-5 pb-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">@GetText("Home.MembershipPlansTitle", "Membership plans")</h2>
        <span class="text-muted small">@GetText("Home.MembershipPlansEntityLabel", "Entity: MembershipPlan")</span>
    </div>

    <div class="row g-3">
        @if (membershipPlans.Any())
        {
            foreach (var plan in membershipPlans)
            {
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start">
                                <h5 class="mb-1">@plan.Name</h5>
                                <span class="badge text-bg-light">@($"{plan.DurationInDays} days")</span>
                            </div>
                            <p class="text-muted mb-3">@GetText($"Home.Plan.{plan.Name}.Description", GetText("Home.PlanDefaultDescription", "Membership plan"))</p>
                            <p class="display-6 fw-bold mb-3">@($"{plan.Price:0.##} PLN")</p>
                            <div class="d-grid">
                                <a asp-controller="MembershipPlans" asp-action="Index" class="btn btn-outline-primary">@GetText("Home.PlanChooseButton", "Choose plan")</a>
                            </div>
                            <p class="text-muted small mt-2 mb-0">@GetText("Home.PlanHintText", "Later: creates Membership")</p>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</section>