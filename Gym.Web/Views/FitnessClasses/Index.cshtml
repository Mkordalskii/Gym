@model IEnumerable<Gym.Data.Models.Core.FitnessClass>
@{
    var parameters = ViewBag.Parameters as Dictionary<string, string> ?? new Dictionary<string, string>();

    string GetText(string key, string fallback)
    {
        return parameters.ContainsKey(key) ? parameters[key] : fallback;
    }

    ViewData["Title"] = GetText("FitnessClasses.Title", "Class schedule");
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<section class="container my-5 pb-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">@GetText("FitnessClasses.Title", "Class schedule")</h1>
    </div>

    <div class="row g-3">
        @if (Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-body">
                            <h5 class="mb-2">@item.Title</h5>
                            <p class="text-muted small mb-2">
                                @item.StartTime.ToString("dd.MM.yyyy HH:mm")
                            </p>
                            <p class="mb-1"><strong>Room:</strong> @item.Room</p>
                            <p class="mb-1"><strong>Duration:</strong> @item.DurationInMinutes min</p>
                            <p class="mb-0"><strong>Capacity:</strong> @item.Capacity</p>
                            <form asp-controller="Bookings" asp-action="Create" method="post">
                                <input type="hidden" name="fitnessClassId" value="@item.Id" />
                                <button class="btn btn-primary btn-sm">Book</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-info mb-0">
                    @GetText("FitnessClasses.Empty", "No classes available.")
                </div>
            </div>
        }
    </div>
</section>

