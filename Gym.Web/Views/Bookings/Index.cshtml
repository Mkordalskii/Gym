@model IEnumerable<Gym.Data.Models.Core.Booking>

@{
    var parameters = ViewBag.Parameters as Dictionary<string, string> ?? new Dictionary<string, string>();

    string GetText(string key, string fallback)
    {
        return parameters.ContainsKey(key) ? parameters[key] : fallback;
    }

    ViewData["Title"] = GetText("Bookings.Title", "My bookings");
}

<section class="container my-5 pb-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">@GetText("Bookings.Title", "My bookings")</h1>
        <a asp-controller="FitnessClasses" asp-action="Index" class="btn btn-outline-primary btn-sm">
            @GetText("Bookings.BackToSchedule", "Back to schedule")
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>@GetText("Bookings.Class", "Class")</th>
                        <th>@GetText("Bookings.Date", "Date")</th>
                        <th>@GetText("Bookings.Room", "Room")</th>
                        <th>@GetText("Bookings.Status", "Status")</th>
                        <th class="text-end">@GetText("Bookings.Actions", "Actions")</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        foreach (var booking in Model)
                        {
                            var isCancelled = booking.Status == "Cancelled";
                            var canCancel = !isCancelled;

                            <tr>
                                <td>@booking.FitnessClass.Title</td>
                                <td>@booking.FitnessClass.StartTime.ToString("dd.MM.yyyy HH:mm")</td>
                                <td>@booking.FitnessClass.Room</td>
                                <td>
                                    <span class="badge @(isCancelled ? "text-bg-secondary" : "text-bg-success")">
                                        @booking.Status
                                    </span>
                                </td>
                                <td class="text-end">
                                    @if (canCancel)
                                    {
                                        <form asp-controller="Bookings" asp-action="Cancel" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@booking.Id" />
                                            <button type="submit" class="btn btn-outline-danger btn-sm">
                                                @GetText("Bookings.Cancel", "Cancel")
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">
                                            @GetText("Bookings.NoAction", "No action")
                                        </span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-muted">
                                @GetText("Bookings.Empty", "You have no bookings yet.")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>